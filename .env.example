# Provider: codex_cli | claude_code | responses_api
LLM_PROVIDER=codex_cli

# Codex CLI provider
CODEX_COMMAND=codex
CODEX_MODEL=gpt-5.3-codex
CODEX_SANDBOX=read-only
CODEX_MODEL_PLANNER=gpt-5.3-codex
CODEX_MODEL_ROUTER=gpt-5.3-codex
CODEX_MODEL_REVIEWER=gpt-5.3-codex
CODEX_MODEL_CODEGEN=gpt-5.3-codex

# Claude Code provider
# CLAUDE_COMMAND=claude
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_TIMEOUT_SECONDS=300
# CLAUDE_MAX_TURNS=1
# CLAUDE_MODEL_PLANNER=claude-sonnet-4-6
# CLAUDE_MODEL_ROUTER=claude-sonnet-4-6
# CLAUDE_MODEL_REVIEWER=claude-sonnet-4-6
# CLAUDE_MODEL_CODEGEN=claude-sonnet-4-6

# Claude Code Executor (multi-turn, tool-enabled for actual task execution)
# CLAUDE_EXECUTOR_MODEL=claude-sonnet-4-6
# CLAUDE_EXECUTOR_TIMEOUT_SECONDS=600
# CLAUDE_EXECUTOR_PERMISSION_MODE=auto
# CLAUDE_EXECUTOR_MAX_TURNS=25

# Optional fallback if you want to use the Responses API instead of Codex CLI.
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-5.2-codex
OPENAI_MODEL_PLANNER=gpt-5.2-codex
OPENAI_MODEL_ROUTER=gpt-5.2-codex
OPENAI_MODEL_REVIEWER=gpt-5.2-codex
OPENAI_MODEL_CODEGEN=gpt-5.2-codex
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REASONING_EFFORT=medium
OPENAI_REASONING_EFFORT_CODEGEN=medium
