# Provider: claude_code (switched from codex_cli — Codex quota exhausted)
LLM_PROVIDER=claude_code

# Claude Code provider
CLAUDE_COMMAND=claude
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT_SECONDS=300
CLAUDE_MAX_TURNS=1
CLAUDE_MODEL_PLANNER=claude-sonnet-4-6
CLAUDE_MODEL_ROUTER=claude-sonnet-4-6
CLAUDE_MODEL_REVIEWER=claude-sonnet-4-6
CLAUDE_MODEL_CODEGEN=claude-opus-4-6

# Claude Code Executor (multi-turn, tool-enabled for actual task execution)
CLAUDE_EXECUTOR_MODEL=claude-opus-4-6
CLAUDE_EXECUTOR_TIMEOUT_SECONDS=1800
CLAUDE_EXECUTOR_PERMISSION_MODE=dangerously-skip-permissions
CLAUDE_EXECUTOR_MAX_TURNS=25
